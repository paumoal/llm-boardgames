# Copy to .env and fill in the keys you have
# Only providers with keys will show as options in the UI

# OpenAI (GPT-4o, GPT-3.5, o3-mini, etc.)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (Claude Sonnet, Haiku, etc.) — optional
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini — optional
# GOOGLE_API_KEY=your-gemini-key-here

# Database (SQLite for local, Render provides PostgreSQL automatically)
DATABASE_URL=sqlite:///boardgames.db
FLASK_DEBUG=true
